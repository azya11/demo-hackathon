{
  "default_mode": "strict",
  "tick_seconds": 2.0,
  "warn_before_close_seconds": 3,
  "escalation": {
    "warn_until_offense": 2,
    "block_from_offense": 3
  },
  "browser": {
    "headless": false,
    "start_url": "about:blank"
  },
  "ai": {
    "model": "gemini-1.5-flash",
    "enabled": true
  },
  "storage": {
    "db_path": "data/sessions.db"
  }
}
